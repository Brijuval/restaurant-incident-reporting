# --- Django Backend Configuration ---
SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# Leave blank to use SQLite locally, or provide PostgreSQL URL for production
# DATABASE_URL=postgres://user:password@host:port/dbname

# AI Service Configurations
# Groq: Get a key from Groq Console: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# --- React Frontend Configuration ---
# Point to your Django backend (defaults to http://localhost:8000 locally)
# VITE_API_URL=https://your-backend-render-app.onrender.com
